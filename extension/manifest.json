{
  "manifest_version": 3,
  "name": "AgenticWeb",
  "version": "1.0.0",
  "description": "Autonomous web agent - type a goal, watch it work",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel"],
  "host_permissions": ["http://localhost:8000/*", "http://localhost:8765/*", "<all_urls>"],
  "background": { "service_worker": "background.js", "type": "module" },
  "action": { "default_popup": "popup.html", "default_title": "AgenticWeb" },
  "side_panel": { "default_path": "sidebar.html" },
  "content_scripts": [{ "matches": ["<all_urls>"], "js": ["content.js"], "run_at": "document_idle" }]
}
