# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: github | gemini | groq | deepseek | claude | openai | azure_openai | openrouter_qwen | openrouter_free | openrouter_auto
AGENT_PROVIDER=github     # Microsoft tech - required for hackathon
GEMINI_MODEL=gemma-4-31b-it
AGENT_MAX_ITERATIONS=8

# ── API Keys (only fill what you use) ─────────────────────────────────────────
GEMINI_API_KEY=           # free → aistudio.google.com/apikey
GITHUB_TOKEN=             # GitHub fine-grained token with Models permission enabled
GITHUB_MODEL=gpt-4o-mini  # options: gpt-4o-mini | Phi-4 | Phi-3.5-mini-instruct
GROQ_API_KEY=             # free → console.groq.com/keys
DEEPSEEK_API_KEY=         # cheap → platform.deepseek.com (model: deepseek-chat → V4 Flash)
ANTHROPIC_API_KEY=        # paid  → console.anthropic.com
OPENAI_API_KEY=           # paid  → platform.openai.com/api-keys
OPENROUTER_API_KEY=       # free/paid router → openrouter.ai/keys
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
# openrouter_auto uses openrouter/auto. It has no extra routing fee, but it can select paid models.
OPENROUTER_SITE_URL=http://127.0.0.1:3000
OPENROUTER_APP_NAME=AgenticWeb
OPENROUTER_TIMEOUT_SECONDS=25
OPENROUTER_MAX_TOKENS=2048
LLM_CALL_TIMEOUT_SECONDS=25
ALLOW_PAID_FALLBACKS=false

# ── Azure OpenAI (Microsoft stack — required for hackathon qualification) ──────
AZURE_OPENAI_API_KEY=     # from Azure AI Foundry → deploy model first
AZURE_OPENAI_ENDPOINT=    # e.g. https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=  # model deployment name, e.g. gpt-4o-mini
AZURE_OPENAI_API_VERSION= # default: 2024-08-01-preview

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=    # from @BotFather

# ── Ports ─────────────────────────────────────────────────────────────────────
GATEWAY_PORT=8000      # main gateway (REST + WS + Telegram)
AGENT_PORT=8765        # agent/MCP server

# ── Browser ───────────────────────────────────────────────────────────────────
BROWSER_HEADLESS=true
BROWSER_SLOW_MO_MS=0
BROWSER_SCREENSHOT_TIMEOUT_MS=8000
# Render runs Chromium headlessly. Use the Dockerfile/Playwright image or run:
#   python -m playwright install --with-deps chromium
